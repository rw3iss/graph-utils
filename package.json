{
  "name": "@rw3iss/graph-utils",
  "version": "0.2.0",
  "description": "Modular vanilla-TypeScript canvas drawing toolkit: scales, viewports, layers, and reusable overlays that work on a bare canvas or on top of a TradingView chart.",
  "author": "Ryan Weiss <rw3iss@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./chart": {
      "types": "./dist/chart/index.d.ts",
      "import": "./dist/chart/index.js",
      "require": "./dist/chart/index.cjs"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js",
      "require": "./dist/adapters/index.cjs"
    },
    "./overlays": {
      "types": "./dist/overlays/index.d.ts",
      "import": "./dist/overlays/index.js",
      "require": "./dist/overlays/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "playground": "pnpm --filter graph-utils-playground dev",
    "prepare": "tsup"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "happy-dom": "^20.9.0",
    "lightweight-charts": "^5.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "peerDependencies": {
    "lightweight-charts": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "lightweight-charts": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rw3iss/graph-utils.git"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "canvas",
    "chart",
    "drawing",
    "visualization",
    "trading",
    "overlay",
    "graph"
  ]
}
